{
  "expo": {
    "name": "SportsCal",
    "slug": "sportscal",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sportscal",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fivekconsulting.sportscal"
    },
    "android": {
      "package": "com.fivekconsulting.sportscal"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f1629"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://sportscal-production.up.railway.app"
    }
  }
}