{
  "expo": {
    "name": "SportsCal",
    "slug": "sportscal",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sportscal",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fivekconsulting.sportscal",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fivekconsulting.sportscal",
      "permissions": [
        "android.permission.INTERNET",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f1629"
        }
      ],
      "@react-native-firebase/app",
      [
        "react-native-fbsdk-next",
        {
          "appID": "842222471603112",
          "clientToken": "89f541b082b49038693c407e22425644",
          "displayName": "SportsCal",
          "scheme": "fb842222471603112",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier helps us measure ads we run and improve SportsCal."
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "SportsCal needs photo library access so you can scan a printed schedule and we'll extract the games and practices.",
          "cameraPermission": "SportsCal uses the camera so you can take a photo of a printed schedule and we'll extract the games and practices."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "FirebaseCoreInternal",
                "modular_headers": true
              },
              {
                "name": "FirebaseCore",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          },
          "androidIntentFilters": ["text/*", "image/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://sportscal-production.up.railway.app",
      "router": {},
      "eas": {
        "projectId": "40370800-083e-405d-b0db-cde4569ef7a0"
      }
    },
    "owner": "5kconsulting",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/40370800-083e-405d-b0db-cde4569ef7a0"
    }
  }
}
